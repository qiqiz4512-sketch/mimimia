{
  "name": "mimimia",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "playwright test tests/visual --project=chromium-webgl2",
    "test:functional": "playwright test tests/e2e/full-flow.spec.ts",
    "test:acceptance": "node scripts/testing/run-acceptance.mjs",
    "test:public": "node scripts/testing/run-public-suite.mjs",
    "test:public:flow": "node scripts/testing/run-public-acceptance.mjs",
    "test:public:focus": "node scripts/testing/run-public-focus-acceptance.mjs",
    "test:all": "npm run test:unit -- --run && npm run test:e2e",
    "assets:private-check": "node scripts/assets/verify-private-boundary.mjs",
    "assets:ledger-check": "node scripts/assets/verify-ledger.mjs",
    "assets:export": "node scripts/assets/export-runtime-art.mjs",
    "assets:size-check": "npm run build && node scripts/assets/measure-brotli-size.mjs",
    "art:validate-layers": "node scripts/art/validate-layer-pack.mjs",
    "art:render-extremes": "node scripts/art/render-layer-extremes.mjs",
    "audio:generate": "node scripts/audio/generate-original-audio.mjs",
    "audio:validate": "node scripts/audio/validate-audio.mjs",
    "audio:review": "node scripts/audio/render-audio-review.mjs",
    "perf:profile": "node scripts/performance/run-summon-profile.mjs",
    "perf:soak": "node scripts/performance/run-reset-soak.mjs",
    "perf:transfer": "node scripts/performance/measure-transfer.mjs",
    "release:package": "node scripts/release/package-release.mjs",
    "release:verify": "node scripts/release/verify-release.mjs",
    "rendering:forbidden-check": "node scripts/testing/assert-no-forbidden-rendering.mjs"
  },
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/three": "0.185.0",
    "sharp": "0.34.3",
    "typescript": "5.9.2",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  }
}
